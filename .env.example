# ═══════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES - KEEP THIS FILE SECRET!
# ═══════════════════════════════════════════════════════════════
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file and rename it to ".env.local"
# 2. Fill in your actual API keys (instructions below)
# 3. NEVER commit .env.local to Git (it's in .gitignore)
# 
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# GOOGLE ANALYTICS 4 (GA4)
# ───────────────────────────────────────────────────────────────
# HOW TO GET:
# 1. Go to https://analytics.google.com/
# 2. Create a new property (or use existing)
# 3. Go to Admin > Data Streams > Web
# 4. Copy the "Measurement ID" (starts with G-)
# 
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ───────────────────────────────────────────────────────────────
# MICROSOFT CLARITY
# ───────────────────────────────────────────────────────────────
# HOW TO GET:
# 1. Go to https://clarity.microsoft.com/
# 2. Create a new project
# 3. Copy the "Project ID"
# 
# Example: abc123def456
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ───────────────────────────────────────────────────────────────
# TIKTOK PIXEL
# ───────────────────────────────────────────────────────────────
# HOW TO GET:
# 1. Go to TikTok Ads Manager
# 2. Assets > Events > Web Events
# 3. Create a pixel and copy the Pixel ID
# 
# Example: ABCDEFGHIJKLMNOP
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# ───────────────────────────────────────────────────────────────
# META PIXEL (Facebook/Instagram)
# ───────────────────────────────────────────────────────────────
# HOW TO GET:
# 1. Go to Facebook Business Manager
# 2. Business Settings > Data Sources > Pixels
# 3. Copy the Pixel ID
# 
# Example: 123456789012345
NEXT_PUBLIC_META_PIXEL_ID=

# ───────────────────────────────────────────────────────────────
# SUPABASE (Database)
# ───────────────────────────────────────────────────────────────
# HOW TO GET:
# 1. Go to https://supabase.com/
# 2. Create a new project (FREE tier)
# 3. Go to Project Settings > API
# 4. Copy both URL and anon key
# 
# Example URL: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Example Key: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ───────────────────────────────────────────────────────────────
# RESEND (Email Service) - OPTIONAL FOR MVP
# ───────────────────────────────────────────────────────────────
# HOW TO GET:
# 1. Go to https://resend.com/
# 2. Create account (100 free emails/day)
# 3. Copy API key
# 
# Example: re_123456789_abcdefghijklmnop
RESEND_API_KEY=

# ───────────────────────────────────────────────────────────────
# SITE CONFIGURATION
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
